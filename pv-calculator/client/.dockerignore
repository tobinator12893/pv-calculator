# Source: https://docs.docker.com/build/concepts/context/#dockerignore-files

# Dependencies — rebuilt inside container via npm ci
node_modules
**/node_modules

# Build output — produced inside container by Vite build stage
# Note: dist is especially large for this project due to Cesium assets (100+ MB)
dist

# Secrets — NEVER include in image
# The client .env contains the real VITE_CESIUM_ION_TOKEN
.env
.env.*
!.env.example

# Git metadata — not needed in image
.git
.gitignore

# Editor/OS artifacts
.DS_Store
.vscode
*.local

# Logs
*.log
npm-debug.log*

# Type checking artifacts (generated during build inside container)
*.tsbuildinfo
